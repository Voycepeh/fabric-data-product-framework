{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/dataset_contract.schema.json",
  "title": "Dataset Contract",
  "type": "object",
  "required": [
    "dataset",
    "source",
    "target",
    "refresh",
    "keys",
    "policies",
    "quality_rules",
    "governance",
    "contracts",
    "transformations"
  ],
  "properties": {
    "dataset": {
      "type": "object",
      "required": [
        "name",
        "description",
        "domain",
        "owner",
        "steward",
        "purpose",
        "approved_use_cases",
        "not_approved_use_cases"
      ],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "domain": { "type": "string" },
        "owner": { "type": "string" },
        "steward": { "type": "string" },
        "purpose": { "type": "string" },
        "approved_use_cases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "not_approved_use_cases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "required": ["system", "table", "type", "description"],
      "properties": {
        "system": { "type": "string" },
        "table": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "target": {
      "type": "object",
      "required": ["lakehouse", "schema", "table", "write_mode"],
      "properties": {
        "lakehouse": { "type": "string" },
        "schema": { "type": "string" },
        "table": { "type": "string" },
        "write_mode": {
          "type": "string",
          "enum": ["append", "overwrite", "merge"]
        }
      }
    },
    "refresh": {
      "type": "object",
      "required": ["frequency", "mode", "watermark_column", "partition_column"],
      "properties": {
        "frequency": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": [
            "full_refresh",
            "incremental",
            "backfill",
            "schema_evolution",
            "dry_run",
            "profile_only"
          ]
        },
        "watermark_column": { "type": "string" },
        "partition_column": { "type": "string" }
      }
    },
    "keys": {
      "type": "object",
      "required": ["business_keys"],
      "properties": {
        "business_keys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "policies": {
      "type": "object",
      "required": ["schema_drift", "data_drift", "incremental_safety"],
      "properties": {
        "schema_drift": {
          "type": "object",
          "required": [
            "block_on_removed_column",
            "block_on_type_change",
            "warn_on_added_column",
            "require_approval_for_new_columns"
          ],
          "properties": {
            "block_on_removed_column": { "type": "boolean" },
            "block_on_type_change": { "type": "boolean" },
            "warn_on_added_column": { "type": "boolean" },
            "require_approval_for_new_columns": { "type": "boolean" }
          }
        },
        "data_drift": {
          "type": "object",
          "required": [
            "enabled",
            "baseline",
            "block_on_critical_drift",
            "warn_on_distribution_drift"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "baseline": { "type": "string" },
            "block_on_critical_drift": { "type": "boolean" },
            "warn_on_distribution_drift": { "type": "boolean" }
          }
        },
        "incremental_safety": {
          "type": "object",
          "required": [
            "block_on_historical_partition_change",
            "closed_partition_grace_days",
            "allow_late_arriving_records",
            "lookback_partitions"
          ],
          "properties": {
            "block_on_historical_partition_change": { "type": "boolean" },
            "closed_partition_grace_days": { "type": "integer", "minimum": 0 },
            "allow_late_arriving_records": { "type": "boolean" },
            "lookback_partitions": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "quality_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "rule_type", "severity", "reason"],
        "properties": {
          "rule_id": { "type": "string" },
          "rule_type": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          },
          "reason": { "type": "string" },
          "column": { "type": "string" },
          "columns": {
            "type": "array",
            "items": { "type": "string" }
          },
          "threshold": { "type": "number" },
          "pattern": { "type": "string" },
          "accepted_values": {
            "type": "array",
            "items": {}
          }
        }
      }
    },
    "governance": {
      "type": "object",
      "required": ["dataset_classification", "columns"],
      "properties": {
        "dataset_classification": { "type": "string" },
        "columns": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["classification", "semantic_type", "pii", "handling_rule"],
            "properties": {
              "classification": { "type": "string" },
              "semantic_type": { "type": "string" },
              "pii": { "type": "boolean" },
              "handling_rule": { "type": "string" }
            }
          }
        }
      }
    },
    "contracts": {
      "type": "object",
      "required": ["upstream", "downstream"],
      "properties": {
        "upstream": {
          "type": "object",
          "required": ["expected_columns", "expected_freshness", "breaking_changes"],
          "properties": {
            "expected_columns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "expected_freshness": { "type": "string" },
            "breaking_changes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "downstream": {
          "type": "object",
          "required": ["grain", "guaranteed_columns", "quality_expectations"],
          "properties": {
            "grain": { "type": "string" },
            "guaranteed_columns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "quality_expectations": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "transformations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "name", "description", "reason", "input", "output"],
        "properties": {
          "step_id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "reason": { "type": "string" },
          "input": { "type": "string" },
          "output": { "type": "string" },
          "columns_used": {
            "type": "array",
            "items": { "type": "string" }
          },
          "columns_created": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
